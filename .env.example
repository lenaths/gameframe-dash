SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-or-publishable-key"

# Server-only secrets. Never prefix these with VITE_.
SUPABASE_SERVICE_ROLE_KEY="your-server-only-service-role-key"
PTERODACTYL_PANEL_URL="https://panel.example.com"
PTERODACTYL_APP_API_KEY="ptla_your-application-api-key"
PTERODACTYL_CLIENT_API_KEY="ptlc_your-client-api-key"

STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_SUCCESS_URL="http://localhost:5173/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}"
STRIPE_CANCEL_URL="http://localhost:5173/pricing?checkout=cancelled"

RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="XNTServers <no-reply@example.com>"

CURSEFORGE_API_KEY="cf_your-api-key"

# Sentry monitoring. VITE_SENTRY_DSN is public by design; SENTRY_DSN remains server-only.
VITE_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
